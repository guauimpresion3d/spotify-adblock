  },
  "homepage": "https://github.com/AnanthVivekanand/spotify-adblock#readme",
  "dependencies": {
    "colors": "^1.4.0",
    "http-mitm-proxy": "^0.8.2",
    "micromatch": "^4.0.2"
  },
  "devDependencies": {
    "@types/colors": "^1.2.2",
    "@types/micromatch": "^4.0.3",
    "@types/node": "^20.10.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.0"
  }
}
